+// ── Lightweight distance/ETA "AI" — heuristic by route pair + time-of-day ──
+const DISTANCES = {
+  "High Street (Town)→Drostdy Res": 1.8, "High Street (Town)→Eden Grove": 2.1, "High Street (Town)→Jan Smuts Res": 2.4,
+  "High Street (Town)→Beit Res": 2.2, "High Street (Town)→Rhodes Main Gate": 1.6, "High Street (Town)→Marjorie Ramsey": 2.5,
+  "Rhodes Main Gate→Drostdy Res": 0.6, "Rhodes Main Gate→Eden Grove": 0.8, "Rhodes Main Gate→High Street (Town)": 1.6,
+  "MiCasa / Champs Bar→Drostdy Res": 2.0, "MiCasa / Champs Bar→Jan Smuts Res": 2.4, "Rat & Parrot→Drostdy Res": 1.9,
+  "Makhanda Taxi Rank→Joza Township": 3.4, "PnP African Street→Rhodes Main Gate": 1.7,
+};
+function estimateTrip() {
+  const from = qs("#from").value, to = qs("#to").value;
+  const when = qs("#when").value, riders = qs("#riders").value;
+  if (from === to) { toast("Pickup and drop-off must be different.", "error"); return null; }
+  const km = DISTANCES[`${from}→${to}`] || DISTANCES[`${to}→${from}`] || (2 + Math.random() * 2);
+  const baseMinPerKm = when === "peak" ? 4.5 : when === "late" ? 3.0 : 3.6;
+  const etaMin = Math.max(4, Math.round(km * baseMinPerKm + 2));
+  const baseFare = 25 + Math.round(km * 12);
+  const surcharge = when === "late" ? 10 : when === "peak" ? 8 : 0;
+  const groupBump = ({"Just me":0, "2 of us":5, "3 of us":10, "4 of us":15})[riders] || 0;
+  const fare = baseFare + surcharge + groupBump;
+  return { km: km.toFixed(1), etaMin, fare, from, to };
+}
+function renderEstimate(e) {
+  qs("#eta").textContent = e.etaMin + " min";
+  qs("#fare").textContent = "R" + e.fare;

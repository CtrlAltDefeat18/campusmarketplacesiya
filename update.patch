+  if (guard) {
+    const c = qs("#cName").value.trim(), p = qs("#cPhone").value.trim();
+    if (!c || !p) { toast("Add a Guardian contact first.", "error"); return; }
+    sharing = true;
+    qs("#trackingNote").textContent = `🛡️ Sharing this trip with ${c}. They'll be alerted if you don't arrive in time.`;
+    qs("#trackingNote").classList.remove("hidden");
+    qs("#liveDot").classList.remove("hidden");
+  }
+  const e = estimateTrip(); if (!e) return;
+  tripStart = Date.now(); tripETA = e.etaMin * 60 * 1000;
+  qs("#status").textContent = "🚗 En route";
+  qs("#startTrip").classList.add("hidden");
+  qs("#endTrip").classList.remove("hidden");
+  toast("Trip started — stay safe 💜");
+  if (tripTimer) clearInterval(tripTimer);
+  tripTimer = setInterval(() => {
+    const elapsed = Date.now() - tripStart;
+    const remain = Math.max(0, Math.round((tripETA - elapsed) / 1000));
+    qs("#eta").textContent = remain + "s left";
+    if (elapsed > tripETA * 1.2 && sharing) {
+      qs("#status").textContent = "⚠️ Overdue — alerting contact";
+      qs("#trackingNote").textContent = `⚠️ Alert sent to your Guardian contact. Stay calm — help is on the way if you need it.`;
+      clearInterval(tripTimer);
+    }
+  }, 1000);
+});
+
+qs("#endTrip").addEventListener("click", () => {
+  if (tripTimer) clearInterval(tripTimer);
+  qs("#status").textContent = "🏠 Arrived safely";
+  qs("#endTrip").classList.add("hidden");
+  qs("#liveDot").classList.add("hidden");
+  qs("#trackingNote").textContent = `✅ Trip ended. Tracking data cleared.`;
+  toast("Glad you got home safe 🏠💜", "wa");
+  sharing = false;
+});
+
+// ── Drivers (seed list — real directory ships via admin) ──
+const DRIVERS = [
+  { name: "Mr Zwide", car: "White Avanza", rating: 4.9, trips: 320, badges: ["Verified","Late-night"] },

+// ── Enter modal ──
+let mode = "signup";
+function openEnter(which) {
+  mode = which || "signup";
+  switchTab(mode);
+  qs("#enter").classList.remove("hidden");
+  document.body.style.overflow = "hidden";
+}
+function closeEnter() {
+  qs("#enter").classList.add("hidden");
+  document.body.style.overflow = "";
+  if (location.hash === "#enter") history.replaceState(null, "", location.pathname + location.search);
+}
+function switchTab(which) {
+  mode = which;
+  const signup = which === "signup";
+  qs("#nameWrap").style.display = signup ? "" : "none";
+  qs("#extraWrap").style.display = signup ? "" : "none";
+  qs("#enterSubmit").textContent = signup ? "Create my account" : "Log in";
+  qs("#tabSignup").className = "py-2 rounded-lg text-sm font-semibold transition " + (signup ? "bg-violet-600 text-white" : "text-white/60");
+  qs("#tabLogin").className = "py-2 rounded-lg text-sm font-semibold transition " + (!signup ? "bg-violet-600 text-white" : "text-white/60");
+}
+function browseGuest() {
+  setGuest(true);
+  toast("Browsing as guest 👀 — sign up anytime to unlock everything");
+  setTimeout(() => (location.href = nextUrl()), 500);
+}
+window.openEnter = openEnter; window.closeEnter = closeEnter; window.switchTab = switchTab; window.browseGuest = browseGuest;

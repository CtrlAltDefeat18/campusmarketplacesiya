+      <span class="badge absolute top-2 left-2 bg-white/90 backdrop-blur">${esc(p.category)}</span>
+    </div>
+    <div class="p-3">
+      <div class="font-semibold text-sm leading-snug line-clamp-2 min-h-[2.5em]">${esc(p.title)}</div>
+      <div class="font-syne font-extrabold text-plum mt-1">${money(p.price)}</div>
+    </div></a>`;
+}
+function ncard(n) {
+  return `<a href="/news" class="card card-hover overflow-hidden block">
+    <div class="aspect-video bg-plum-wash flex items-center justify-center text-5xl">${n.imageUrl?`<img src="${esc(n.imageUrl)}" class="w-full h-full object-cover" alt=""/>`:`<span>${esc(n.emoji||'📰')}</span>`}</div>
+    <div class="p-4"><span class="badge mb-2">${esc(n.tag||'News')}</span>
+      <h3 class="font-syne font-bold leading-snug">${esc(n.title)}</h3>
+      <p class="text-sm text-muted mt-1 line-clamp-2">${esc(n.excerpt||'')}</p></div></a>`;
+}
